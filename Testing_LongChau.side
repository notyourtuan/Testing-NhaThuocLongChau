    "id": "de902b18-0001-4ac7-acb0-ca79d27bf3a1",
    "name": "TC27 - Kiểm tra logic giảm giá flash sale",
    "commands": [{
      "id": "e12afd4e-f651-4942-be82-81fed02ef2f6",
      "comment": "",
      "command": "open",
      "target": "/",
      "targets": [],
      "value": ""
    }, {
      "id": "d90d86b3-bfdb-4425-ad20-74317df94438",
      "comment": "",
      "command": "open",
      "target": "/flash-sale/flash-sale-1",
      "targets": [],
      "value": ""
    }, {
      "id": "32298187-4421-4da9-8533-14d2abd22520",
      "comment": "",
      "command": "storeText",
      "target": "xpath=(//div[@data-state='active' and @role='tabpanel']//div[contains(@class, 'bgi-promotion-tag')]//span)[1]",
      "targets": [],
      "value": "rawDiscount"
    }, {
      "id": "699aac6f-1904-4751-9dc6-c6127b018a39",
      "comment": "",
      "command": "storeText",
      "target": "xpath=(//div[@data-state='active' and @role='tabpanel']//div[contains(@class, 'text-blue-5')]/span[contains(@class, 'font-semibold')])[1]",
      "targets": [],
      "value": "rawNewPrice"
    }, {
      "id": "3c5988a2-c019-499c-a59a-c79d13640af9",
      "comment": "",
      "command": "storeText",
      "target": "xpath=(//div[@data-state='active' and @role='tabpanel']//div[contains(@class, 'line-through')])[1]",
      "targets": [],
      "value": "rawOldPrice"
    }, {
      "id": "a2ad5561-7089-4a32-84bf-14b7f76ec8ed",
      "comment": "",
      "command": "executeScript",
      "target": "return \"${rawDiscount}\".replace(/\\D/g, \"\");",
      "targets": [],
      "value": "strDiscount"
    }, {
      "id": "58cda7bc-492b-4587-9131-82796cf5008b",
      "comment": "",
      "command": "executeScript",
      "target": "return parseInt(${strDiscount});",
      "targets": [],
      "value": "numDiscount"
    }, {
      "id": "67f064eb-81ef-477c-92e3-b71f977ab62a",
      "comment": "",
      "command": "executeScript",
      "target": "return \"${rawNewPrice}\".replace(/\\D/g, \"\");",
      "targets": [],
      "value": "strNewPrice"
    }, {
      "id": "f6a89d1e-4769-4ca7-b382-e3facced3fc5",
      "comment": "",
      "command": "executeScript",
      "target": "return parseInt(${strNewPrice});",
      "targets": [],
      "value": "numNewPrice"
    }, {
      "id": "5c51dac0-5d37-4574-9dce-bcc952fffcb9",
      "comment": "",
      "command": "executeScript",
      "target": "return \"${rawOldPrice}\".replace(/\\D/g, \"\");",
      "targets": [],
      "value": "strOldPrice"
    }, {
      "id": "8e883a5d-51e2-44f5-8c56-5a02ae339d6a",
      "comment": "",
      "command": "executeScript",
      "target": "return parseInt(${strOldPrice});",
      "targets": [],
      "value": "numOldPrice"
    }, {
      "id": "250ccdfb-142f-4585-a22b-9c39e6b59c18",
      "comment": "",
      "command": "executeScript",
      "target": "return \"${rawDiscount}\".includes(\"%\");",
      "targets": [],
      "value": "hasPercent"
    }, {
      "id": "70de4833-a5d6-4069-b585-2b07e808ac55",
      "comment": "",
      "command": "executeScript",
      "target": "return Number(${hasPercent});",
      "targets": [],
      "value": "isPercent"
    }, {
      "id": "b3b0f6f4-3679-41fa-b103-27dcc53f26d4",
      "comment": "",
      "command": "executeScript",
      "target": "return 1 - ${isPercent};",
      "targets": [],
      "value": "isFixed"
    }, {
      "id": "cfca6559-92e6-4704-ac40-eea073f7fce6",
      "comment": "",
      "command": "executeScript",
      "target": "return ${numOldPrice} * ${numDiscount} / 100;",
      "targets": [],
      "value": "calcPercentDiscount"
    }, {
      "id": "52beb0f3-978b-4423-9680-6461f69d8d1b",
      "comment": "",
      "command": "executeScript",
      "target": "return ${isPercent} * ${calcPercentDiscount};",
      "targets": [],
      "value": "actualPercentDiscount"
    }, {
      "id": "5f89701e-b76c-4b4d-99de-d7f895ff40d6",
      "comment": "",
      "command": "executeScript",
      "target": "return ${isFixed} * ${numDiscount};",
      "targets": [],
      "value": "actualFixedDiscount"
    }, {
      "id": "33f1ef54-f6bd-4038-b62b-9dadbb65cdc6",
      "comment": "",
      "command": "executeScript",
      "target": "return ${numOldPrice} - ${actualPercentDiscount} - ${actualFixedDiscount};",
      "targets": [],
      "value": "exactPrice"
    }, {
      "id": "db71122f-9991-46ce-b4bb-1166701d1512",
      "comment": "",
      "command": "executeScript",
      "target": "return Math.round(${exactPrice});",
      "targets": [],
      "value": "expectedPrice"
    }, {
      "id": "5fa7f89f-9453-4b51-acb8-6e2b89dd6730",
      "comment": "",
      "command": "verify",
      "target": "expectedPrice",
      "targets": [],
      "value": "${numNewPrice}"
    }]
  }, {
